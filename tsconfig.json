{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@libcss/*": ["src/*"]
    }
  },
  "include": [
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/common/**/*.ts",
    "src/core/**/*.ts",
    "src/core/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/hooks/**/*.tsx",
    "src/parser/**/*.ts",
    "src/parser/**/*.tsx",
    "src/studio/**/*.ts",
    "src/studio/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "tmp", "studio", "**/*.spec.tsx", "**/*.spec.ts"]
}
