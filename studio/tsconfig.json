{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@libcss/studio": ["../src/studio"],
      "@libcss/studio/*": ["../src/studio/*"],
      "@libcss/components": ["../src/components"],
      "@libcss/components/*": ["../src/components/*"],
      "@libcss/common": ["../src/common"],
      "@libcss/common/*": ["../src/common/*"],
      "@libcss/core": ["../src/core"],
      "@libcss/core/*": ["../src/core/*"],
      "@libcss/hooks": ["../src/hooks"],
      "@libcss/hooks/*": ["../src/hooks/*"],
      "@libcss/parser": ["../src/parser"],
      "@libcss/parser/*": ["../src/parser/*"],
      "@libcss/layout": ["../src/components/layout"],
      "@libcss/layout/*": ["../src/components/layout/*"],
      "d3-*": ["./node_modules/@types/d3-*", "./node_modules/d3-*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../src/**/*.ts", "../src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
