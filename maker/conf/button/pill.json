  },
  "style": {
    "base": {
      "backgroundColor": "#8b5cf6",
      "color": "#ffffff",
      "fontSize": 14,
      "fontWeight": 600,
      "textTransform": "none",
      "letterSpacing": 0.5,
      "padding": {
