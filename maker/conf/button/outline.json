{
  "name": "Outline",
  "props": {
    "label": "Outline",
    "icon": "",
    "iconPosition": "left"
  },
  "style": {
    "base": {
      "backgroundColor": "transparent",
      "color": "#3b82f6",
      "fontSize": 25,
      "fontWeight": 500,
      "textTransform": "capitalize",
      "letterSpacing": 2,
      "padding": {
        "top": 11,
        "right": 17,
        "bottom": 10,
        "left": 24
      },
      "minWidth": 0,
      "border": {
        "radius": 42,
        "width": 5,
        "color": "#865e3c",
        "style": "dotted"
      },
      "opacity": 0.8,
      "cursor": "pointer",
      "transition": {
        "property": "all",
        "duration": 0.5,
        "timing": "ease-in-out",
        "delay": 0
      },
      "shadow": {
        "x": 0,
        "y": 20,
        "blur": 25,
        "spread": -5,
        "color": "rgba(0,0,0,0.1)"
      },
      "transform": {
        "scale": 1,
        "rotate": 0,
        "skewX": 0,
        "skewY": 0,
        "translateX": 0,
        "translateY": 0
      },
      "lineHeight": 1.2,
      "gap": 8,
      "overflow": "hidden"
    },
    "hover": {
      "backgroundColor": "#3b82f6",
      "color": "#ffffff",
      "borderColor": "#3b82f6",
      "transform": {
        "scale": 1,
        "rotate": 0,
        "skewX": 0,
        "skewY": 0,
        "translateX": 0,
        "translateY": 0
      },
      "shadow": {
        "x": 0,
        "y": 0,
        "blur": 0,
        "spread": 0,
        "color": "rgba(0,0,0,0)"
      }
    },
    "active": {
      "transform": {
        "scale": 0.97,
        "translateY": 1
      },
      "shadow": {
        "blur": 4,
        "color": "rgba(0,0,0,0.15)"
      }
    },
    "disabled": {
      "opacity": 0.5,
      "cursor": "not-allowed",
      "grayscale": false
