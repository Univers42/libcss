{
  "name": "New Button",
  "props": {
    "label": "Click me",
    "icon": "",
    "iconPosition": "left"
  },
  "style": {
    "base": {
      "backgroundColor": "#c22e2e",
      "color": "#d4c3e5",
      "fontSize": 14,
      "fontWeight": 800,
      "textTransform": "uppercase",
      "letterSpacing": 7.5,
      "padding": {
        "top": 21,
        "right": 49,
        "bottom": 18,
        "left": 60
      },
      "minWidth": 150,
      "border": {
        "radius": 21,
        "width": 3,
        "color": "#274f91",
        "style": "dashed"
      },
      "opacity": 1,
      "transition": {
        "property": "all",
        "duration": 0.5,
        "timing": "ease-in-out",
        "delay": 0
      },
      "cursor": "default",
      "shadow": {
        "x": 0,
        "y": 20,
        "blur": 25,
        "spread": -5,
        "color": "rgba(0,0,0,0.1)"
      },
      "transform": {
        "scale": 1,
        "rotate": 0,
        "skewX": 0,
        "skewY": 0,
        "translateX": 0,
        "translateY": 0
      },
      "lineHeight": 1.2,
      "gap": 8,
      "overflow": "hidden"
    },
    "hover": {
      "backgroundColor": "#9c900d",
      "color": "#ffffff",
      "borderColor": "#8724eb",
      "transform": {
        "scale": 1,
        "rotate": 0,
        "skewX": 0,
        "skewY": 0,
        "translateX": 0,
        "translateY": 1
      },
      "shadow": {
        "x": 0,
        "y": 8,
        "blur": 25,
        "spread": 0,
        "color": "rgba(0,0,0,0.2)"
      }
    },
    "active": {
      "transform": {
        "scale": 0.97,
        "translateY": 1
      },
      "shadow": {
        "blur": 4,
        "color": "rgba(0,0,0,0.15)"
      }
    },
    "disabled": {
      "opacity": 0.5,
      "cursor": "not-allowed",
      "grayscale": false
    }
  }
}