{
  "extends": "stylelint-config-standard-scss",
  "rules": {
    "selector-class-pattern": "^prisma-[a-z][a-z0-9]*(-[a-z0-9]+)*(__[a-z0-9]+(-[a-z0-9]+)*)?(--[a-z0-9]+(-[a-z0-9]+)*)?$",
    "scss/at-rule-no-unknown": [true, {
      "ignoreAtRules": ["use", "forward", "include", "mixin", "if", "else", "each", "for", "function", "return", "content", "at-root", "warn", "error"]
    }],
    "scss/dollar-variable-pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
    "scss/percent-placeholder-pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
    "no-descending-specificity": null,
    "declaration-empty-line-before": null,
    "custom-property-pattern": "^prisma-[a-z][a-z0-9]*(-[a-z0-9]+)*$",
    "keyframes-name-pattern": "^prisma-[a-z][a-z0-9]*(-[a-z0-9]+)*$|^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
    "max-nesting-depth": 5,
    "selector-max-compound-selectors": 4,
    "color-named": "never",
    "property-no-vendor-prefix": [true, {
      "ignoreProperties": ["-webkit-text-size-adjust", "-webkit-background-clip", "-webkit-text-fill-color"]
    }],
    "declaration-block-no-duplicate-properties": [true, {
      "ignoreProperties": ["text-size-adjust", "background-clip"]
    }]
  }
}
