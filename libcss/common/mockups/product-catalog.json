{
  "schema": {
    "id": "db-product-catalog",
    "name": "Product Catalog",
    "description": "E-commerce items with pricing, inventory, and categories",
    "icon": "🛍️",
    "primaryProperty": "product",
    "properties": [
      { "id": "product",    "name": "Product",     "type": "text",    "required": true },
      { "id": "sku",        "name": "SKU",         "type": "text" },
      { "id": "category",   "name": "Category",    "type": "select",  "config": {
        "options": [
          { "id": "cat1", "label": "Electronics",  "color": "#3b82f6" },
          { "id": "cat2", "label": "Clothing",     "color": "#a855f7" },
          { "id": "cat3", "label": "Home & Garden","color": "#22c55e" },
          { "id": "cat4", "label": "Sports",       "color": "#f59e0b" },
          { "id": "cat5", "label": "Books",        "color": "#6366f1" },
          { "id": "cat6", "label": "Toys",         "color": "#ec4899" }
        ]
      }},
      { "id": "price",      "name": "Price",       "type": "number",  "config": { "format": "currency", "currencySymbol": "$" } },
      { "id": "stock",      "name": "Stock",       "type": "number",  "config": { "format": "number" } },
      { "id": "rating",     "name": "Rating",      "type": "number",  "config": { "format": "number" } },
      { "id": "status",     "name": "Status",      "type": "status",  "config": {
        "statusOptions": [
          { "id": "ps1", "label": "Active",        "color": "#22c55e" },
          { "id": "ps2", "label": "Draft",         "color": "#94a3b8" },
          { "id": "ps3", "label": "Discontinued",  "color": "#ef4444" },
          { "id": "ps4", "label": "Low Stock",     "color": "#f59e0b" }
        ]
      }},
      { "id": "tags",       "name": "Tags",        "type": "multi_select", "config": {
        "options": [
          { "id": "pt1", "label": "New Arrival",   "color": "#3b82f6" },
          { "id": "pt2", "label": "Best Seller",   "color": "#22c55e" },
          { "id": "pt3", "label": "Sale",          "color": "#ef4444" },
          { "id": "pt4", "label": "Eco-Friendly",  "color": "#10b981" },
          { "id": "pt5", "label": "Premium",       "color": "#f59e0b" }
        ]
      }},
      { "id": "vendor",     "name": "Vendor",      "type": "text" },
      { "id": "weight",     "name": "Weight (kg)", "type": "number",  "config": { "format": "number" } },
      { "id": "url",        "name": "Product URL",  "type": "url" },
      { "id": "added",      "name": "Date Added",  "type": "date" },
      { "id": "featured",   "name": "Featured",    "type": "checkbox" },
      { "id": "desc",       "name": "Description", "type": "text" },
      { "id": "pid",        "name": "ID",          "type": "number_id" }
    ]
  },
