  "views": [
    { "id": "v1", "name": "All Products",   "type": "table",   "propertyVisibility": { "product": true, "sku": true, "category": true, "price": true, "stock": true, "rating": true, "status": true, "tags": true, "vendor": true, "added": true, "featured": true, "pid": true }, "filters": [], "sorts": [{ "property": "pid", "direction": "asc" }] },
    { "id": "v2", "name": "By Category",    "type": "board",   "propertyVisibility": { "product": true, "price": true, "stock": true, "status": true }, "filters": [], "sorts": [{ "property": "price", "direction": "desc" }], "groupBy": { "property": "category" }, "boardOptions": { "groupProperty": "category", "showCardCover": false, "cardSize": "medium" } },
    { "id": "v3", "name": "Product Gallery", "type": "gallery", "propertyVisibility": { "product": true, "price": true, "category": true, "rating": true, "status": true, "desc": true }, "filters": [{ "property": "status", "operator": "eq", "value": "Active" }], "sorts": [{ "property": "rating", "direction": "desc" }], "galleryOptions": { "cardSize": "large", "showDescription": true } },
    { "id": "v4", "name": "Low Stock Alert","type": "list",    "propertyVisibility": { "product": true, "sku": true, "stock": true, "status": true, "vendor": true }, "filters": [{ "property": "stock", "operator": "lte", "value": 20 }], "sorts": [{ "property": "stock", "direction": "asc" }] },
    { "id": "v5", "name": "Price Chart",    "type": "chart",   "propertyVisibility": { "category": true, "price": true }, "filters": [{ "property": "status", "operator": "eq", "value": "Active" }], "sorts": [], "chartOptions": { "chartType": "bar", "xAxis": "category", "yAxis": "price", "colorBy": "category" } },
    { "id": "v6", "name": "New This Month", "type": "list",    "propertyVisibility": { "product": true, "category": true, "price": true, "status": true, "tags": true }, "filters": [{ "property": "added", "operator": "gte", "value": "2025-01-01" }], "sorts": [{ "property": "added", "direction": "desc" }] }
  ]
