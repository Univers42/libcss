          { "id": "src3", "label": "LinkedIn",    "color": "#0077b5" },
          { "id": "src4", "label": "Cold Call",   "color": "#f59e0b" },
          { "id": "src5", "label": "Conference",  "color": "#a855f7" },
          { "id": "src6", "label": "Ads",         "color": "#ef4444" }
