      { "id": "owner",      "name": "Owner",       "type": "person" },
      { "id": "website",    "name": "Website",     "type": "url" },
      { "id": "notes",      "name": "Notes",       "type": "text" },
      { "id": "score",      "name": "Lead Score",  "type": "number", "config": { "format": "number" } },
      { "id": "cid",        "name": "ID",          "type": "number_id" }
    ]
