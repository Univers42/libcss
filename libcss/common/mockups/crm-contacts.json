      { "id": "tags",       "name": "Tags",        "type": "multi_select", "config": {
        "options": [
          { "id": "tg1", "label": "Enterprise",   "color": "#6366f1" },
          { "id": "tg2", "label": "Startup",      "color": "#22c55e" },
          { "id": "tg3", "label": "SMB",          "color": "#f59e0b" },
          { "id": "tg4", "label": "VIP",          "color": "#ef4444" },
          { "id": "tg5", "label": "Renewal",      "color": "#3b82f6" }
